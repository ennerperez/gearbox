<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\src\.imports\Template.props" />
  <Import Project="..\src\.imports\Template.targets" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <RootNamespace></RootNamespace>
    <NoWarn>CS0649;CS0169;CA1050;CA1822;CA2211;IDE1006</NoWarn>
    <NukeRootDirectory>..</NukeRootDirectory>
    <NukeScriptDirectory>..</NukeScriptDirectory>
    <NukeTelemetryVersion>1</NukeTelemetryVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Diagnostics.CodeAnalysis.ExcludeFromCodeCoverageAttribute" />
  </ItemGroup>

  <PropertyGroup Condition=" Exists('7za.bin') ">
    <DefineConstants>$(DefineConstants);USING_7ZIP</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Nuke.Common" Version="9.0.4" />
    <PackageReference Include="ConfigurationSubstitutor" Version="1.5.1" />
    <PackageReference Include="DotNetEnv" Version="3.1.1" />
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="9.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.8" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.8" />
    <PackageReference Include="Squid-Box.SevenZipSharp" Version="1.6.2.24" Condition="Exists('7za.bin')" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Condition="'$(TestExecutionFramework)' == 'NUnit'" Include="NUnit.ConsoleRunner" ExcludeAssets="all" Version="3.16.3" />
    <PackageReference Condition="'$(TestExecutionFramework)' == 'XUnit'" Include="xunit.runner.console" ExcludeAssets="all" Version="2.9.3" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="*.sfx" Condition="Exists('*.sfx')">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
    <Content Include="7za.bin" Condition="Exists('7za.bin')">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </Content>
  </ItemGroup>

  <ItemGroup>
    <PackageDownload Include="coverlet.console" Version="[6.0.4]">
      <ExcludeAssets>all</ExcludeAssets>
    </PackageDownload>
    <PackageDownload Condition="'$(UsingDabaseProvider)' == 'true'" Include="dotnet-ef" Version="[9.0.8]" />
    <PackageDownload Condition="'$(UsingSonarQube)' == 'true'" Include="dotnet-sonarscanner" Version="[10.3.0]" />
    <PackageDownload Include="GitVersion.Tool" Version="[6.3.0]" />
    <PackageDownload Include="ReportGenerator" Version="[5.4.8]" />
  </ItemGroup>

</Project>
